---
// =============================================================================
// Contact 页 /contact
//
// 设计：删掉两个表单（提交功能没做，禁用文案伤信任）
// 让电话 + 邮箱直接成为页面主角，大字号居中 + 明显 mailto 按钮
// =============================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site.config';
---

<BaseLayout
  title="Contact Us"
  description="Get in touch with China Crossroads. Email or phone — we reply within 24 hours. Hong Kong based, English-speaking team."
>
  {/* 页头 */}
  <section class="bg-ink-900 text-white pt-36 pb-16 sm:pt-44 sm:pb-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <span class="text-vermilion-500 font-medium text-sm uppercase tracking-wider">Contact</span>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl mt-4 leading-[1.1]">Let's talk about China</h1>
      <p class="mt-5 text-lg text-ink-100/70 max-w-2xl">
        Tell us what you're thinking — dates, cities, who's traveling, what you're curious about. We reply to every message within 24 hours.
      </p>
    </div>
  </section>

  {/* 联系方式 —— 主角，大字号居中 */}
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-16 sm:py-24">
    <div class="text-center mb-12">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Reach us directly</span>
      <h2 class="font-display text-3xl sm:text-4xl text-ink-900 mt-3">Two ways to reach us</h2>
      <p class="mt-3 text-ink-500">No call centers, no contact-form black holes. A real person reads every message.</p>
    </div>

    {/* 两大联系方式卡片 */}
    <div class="grid sm:grid-cols-2 gap-5 mb-10">
      {/* Email —— 主推，最大 */}
      <a href={`mailto:${SITE.email}`} class="group rounded-2xl bg-gradient-to-br from-vermilion-500 to-vermilion-600 text-white p-8 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
        <div class="text-4xl mb-4">✉️</div>
        <div class="text-xs uppercase tracking-wider text-white/70 mb-1">Email — best for detailed inquiries</div>
        <div class="font-display text-2xl sm:text-3xl break-all">{SITE.email}</div>
        <div class="mt-auto pt-6 text-sm text-white/90 flex items-center gap-2">
          <span class="font-medium">Send us an email</span>
          <span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>

      {/* Phone / WhatsApp */}
      <a href={`tel:${SITE.phoneRaw}`} class="group rounded-2xl border-2 border-ink-900 text-ink-900 p-8 hover:bg-ink-900 hover:text-white hover:-translate-y-1 transition-all duration-300 flex flex-col">
        <div class="text-4xl mb-4">📞</div>
        <div class="text-xs uppercase tracking-wider opacity-60 mb-1">Phone / WhatsApp — quick questions</div>
        <div class="font-display text-2xl sm:text-3xl">{SITE.phone}</div>
        <div class="mt-auto pt-6 text-sm opacity-80 flex items-center gap-2">
          <span class="font-medium">Call or message</span>
          <span class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    </div>

    {/* 响应承诺 */}
    <div class="rounded-2xl bg-ink-50 p-6 text-center">
      <div class="text-sm text-ink-500 leading-relaxed">
        <strong class="text-ink-900">Hong Kong time (UTC+8).</strong> We reply within 24 hours, often much faster.
        No deposit required to ask a question — tell us your idea, and we'll tell you honestly what's possible.
      </div>
    </div>
  </section>

  {/* 想写邮件但不知道怎么开头？给个模板 */}
  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <div class="text-center mb-8">
        <h2 class="font-display text-2xl sm:text-3xl text-ink-900">Not sure what to write?</h2>
        <p class="text-ink-500 mt-2">A rough idea is enough. Here's all we need to start:</p>
      </div>

      <div class="rounded-2xl bg-white border border-ink-100 p-6 sm:p-8">
        <ul class="space-y-4 text-sm">
          {[
            { label: 'When', hint: 'Approximate dates or month — "sometime in July 2026" is fine' },
            { label: 'Who', hint: 'Number of travelers — solo, couple, family of four, business delegation' },
            { label: 'What interests you', hint: 'Ancient sites, modern China, food, nature, business — or "not sure, surprise me"' },
            { label: 'Anything specific', hint: 'A place you\'ve always wanted to see, a dietary need, a milestone you\'re celebrating' },
          ].map((item) => (
            <li class="flex gap-4">
              <span class="shrink-0 w-20 font-semibold text-vermilion-600">{item.label}</span>
              <span class="text-ink-500">{item.hint}</span>
            </li>
          ))}
        </ul>

        <div class="mt-6 pt-6 border-t border-ink-100 text-center">
          <a href={`mailto:${SITE.email}`} class="inline-flex items-center rounded-full bg-vermilion-500 px-8 py-3.5 font-semibold text-white hover:bg-vermilion-600 hover:scale-105 transition-all shadow-lg shadow-vermilion-500/30">
            Start your email →
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
