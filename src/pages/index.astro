---
// =============================================================================
// 首页 index.astro —— 全站最重要的 SEO 入口
//
// 设计升级：借鉴电影感 Hero（背景图交叉淡入淡出 + 标签切换）
//   - 背景：4 张中国地标图交叉切换（替代了原提示词里的视频，更轻量对 SEO 更好）
//   - 标题：Instrument Serif 衬线体，编辑感、高级
//   - 元素：液态玻璃徽章、CTA
//   - 下面保留所有 SEO 内容区块
// =============================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import TourImage from '../components/TourImage.astro';
import { SITE } from '../site.config';
import { getCollection } from 'astro:content';
import { getFeaturedTours } from '../lib/tours';

const featuredTours = await getFeaturedTours(3);

// Hero 背景图轮播：4 个标志性场景（古文明 × 科技）
const heroSlides = [
  { src: '/images/tours/beijing-ancient-tech.jpg', label: 'The Great Wall', sub: 'Beijing' },
  { src: '/images/tours/xian-ancient-capital.jpg', label: 'Terracotta Army', sub: 'Xi’an' },
  { src: '/images/tours/shanghai-future-past.jpg', label: 'The Bund', sub: 'Shanghai' },
  { src: '/images/tours/chengdu-pandas-sanxingdui.jpg', label: 'Giant Pandas', sub: 'Chengdu' },
];
---

<BaseLayout
  title=""
  description={SITE.description}
  hero={true}
>
  {/* ============================================================
      1. 电影感 Hero —— 背景图交叉淡入淡出 + 衬线体大标题
      ============================================================ */}
  <section class="relative w-full min-h-screen overflow-hidden bg-black">
    {/* 背景图层：4 张图绝对定位，opacity 切换 */}
    <div class="absolute inset-0">
      {heroSlides.map((slide, i) => (
        <div
          class:list={["hero-slide absolute inset-0 transition-opacity duration-[1500ms] ease-in-out", i === 0 ? 'opacity-100' : 'opacity-0']}
          data-index={i}
        >
          <img src={slide.src} alt={slide.label} class="w-full h-full object-cover animate-ken-burns" />
          {/* 暗色渐变遮罩，让前景文字可读 */}
          <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/70"></div>
        </div>
      ))}
    </div>

    {/* 内容层 */}
    <div class="relative z-10 flex flex-col min-h-screen px-4 sm:px-6">
      <Header transparent />

      {/* Hero 主体内容，居中 */}
      <div class="flex-1 flex flex-col items-center justify-center text-center text-white pt-20 pb-12">
        {/* 徽章：液态玻璃 */}
        <div class="liquid-glass rounded-full px-5 py-2 text-xs sm:text-sm text-white/90 mb-8 animate-rise" style="animation-delay: 100ms">
          ✦ Small-group study tours · Hong Kong based
        </div>

        {/* H1：Instrument Serif 衬线体大标题 */}
        <h1 class="font-display text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[1.05] max-w-5xl animate-rise" style="animation-delay: 300ms">
          Travel China where<br />
          <em class="text-vermilion-500 not-italic">ancient civilization</em> meets<br />
          <em class="text-bronze-500 not-italic">cutting-edge technology</em>
        </h1>

        <p class="mt-8 text-base sm:text-lg text-white/75 max-w-xl leading-relaxed animate-rise" style="animation-delay: 500ms">
          {SITE.subtitle}
        </p>

        {/* CTA 按钮 */}
        <div class="mt-10 flex flex-wrap gap-4 justify-center animate-rise" style="animation-delay: 700ms">
          <Button href="/tours" variant="primary" size="lg">Explore Tours →</Button>
          <Button href="/contact" variant="glassOnDark" size="lg">Plan My Trip</Button>
        </div>

        {/* 背景图切换器：4 个标签 */}
        <div class="mt-16 flex flex-wrap gap-1 sm:gap-2 justify-center animate-rise" style="animation-delay: 900ms">
          {heroSlides.map((slide, i) => (
            <button
              class:list={["hero-tab px-4 py-2 text-xs sm:text-sm rounded-full transition-all duration-300", i === 0 ? 'bg-white text-ink-900' : 'text-white/60 hover:text-white']}
              data-target={i}
            >
              {slide.label}
            </button>
          ))}
        </div>
      </div>

      {/* 底部信任元素 */}
      <div class="pb-8 flex flex-wrap gap-x-8 gap-y-3 justify-center text-xs sm:text-sm text-white/60">
        <span>✓ Hong Kong registered</span>
        <span>✓ English-speaking guides</span>
        <span>✓ Max 12 travelers</span>
        <span class="hidden sm:inline">✓ Pre-trip Chinese course</span>
      </div>
    </div>
  </section>

  {/* ============================================================
      2. 为什么选我们 —— 4 个差异化卖点
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Why us</span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">A new way to experience China</h2>
      <p class="mt-4 text-ink-500">We handle the hard parts of traveling in China — payments, apps, language — so you can focus on the experience.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { icon: '🏯', title: 'Ancient Meets Future', desc: 'The Great Wall in the morning, an AI robotics lab in the afternoon. Two Chinas in one trip.' },
        { icon: '💬', title: 'Language Barrier Solved', desc: 'Free pre-trip Chinese starter course. Plus on-ground English support 24/7.' },
        { icon: '📱', title: 'Tech-Ready China', desc: 'We set you up with WeChat Pay, Didi, translation apps before you land. Travel like a local.' },
        { icon: '🛡️', title: 'Trusted Hong Kong Base', desc: 'Hong Kong registered company, partnered with licensed mainland travel agencies.' },
      ].map((item) => (
        <div class="group rounded-2xl border border-ink-100 bg-white p-6 hover:shadow-xl hover:border-vermilion-500/30 transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-4 transition-transform group-hover:scale-110">{item.icon}</div>
          <h3 class="font-display text-xl text-ink-900 mb-2">{item.title}</h3>
          <p class="text-sm text-ink-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ============================================================
      3. 热门路线
      ============================================================ */}
  <section class="bg-ink-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Tours</span>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">Featured journeys</h2>
          <p class="mt-3 text-ink-500">Curated itineraries designed around school holiday windows.</p>
        </div>
        <a href="/tours" class="hidden sm:inline-flex items-center gap-1 font-semibold text-vermilion-600 hover:text-vermilion-700">
          View all tours →
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {featuredTours.map((tour) => (
          <a href={`/tours/${tour.slug}`} class="group rounded-2xl bg-white overflow-hidden border border-ink-100 hover:shadow-2xl transition-all duration-500">
            <div class="aspect-[16/10] overflow-hidden">
              <TourImage src={tour.data.cardImage || tour.data.heroImage} alt={tour.data.title} className="group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 text-xs text-ink-500 mb-2">
                <span>{tour.data.duration} days</span>
                <span>·</span>
                <span>{tour.data.cities}</span>
              </div>
              <h3 class="font-display text-xl text-ink-900 group-hover:text-vermilion-600 transition-colors">{tour.data.title}</h3>
              <p class="mt-2 text-sm text-ink-500 line-clamp-2">{tour.data.shortDescription}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="font-semibold text-vermilion-600">From ${tour.data.priceFrom}</span>
                <span class="text-sm text-ink-500 group-hover:text-vermilion-600 transition-colors">Details →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============================================================
      4. 古文明 × 科技 的对照展示（这条是这个项目的灵魂）
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">The concept</span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">Two Chinas, one trip</h2>
      <p class="mt-4 text-ink-500">Every itinerary pairs an ancient wonder with its modern counterpart. That contrast is the whole point.</p>
    </div>

    <div class="grid gap-8 md:grid-cols-2">
      <div class="rounded-3xl overflow-hidden bg-ink-900 text-white p-8 sm:p-10">
        <div class="text-vermilion-500 font-medium text-sm uppercase tracking-wider mb-3">Ancient</div>
        <h3 class="font-display text-2xl sm:text-3xl mb-6">5,000 years of civilization</h3>
        <ul class="space-y-3 text-white/75">
          {['The Great Wall, begun 2,500 years ago', 'The Terracotta Army, buried 2,200 years ago', 'Forbidden City, home of 24 emperors', 'Classical gardens and tea ceremonies'].map((item) => (
            <li class="flex items-start gap-3"><span class="text-vermilion-500">◆</span>{item}</li>
          ))}
        </ul>
      </div>
      <div class="rounded-3xl overflow-hidden bg-gradient-to-br from-ink-700 to-ink-900 text-white p-8 sm:p-10">
        <div class="text-bronze-500 font-medium text-sm uppercase tracking-wider mb-3">Future</div>
        <h3 class="font-display text-2xl sm:text-3xl mb-6">Tomorrow, today</h3>
        <ul class="space-y-3 text-white/75">
          {['Level-4 autonomous vehicles on public roads', 'The world’s largest automated port', 'AI robotics labs and smart factories', 'Cashless cities running on super-apps'].map((item) => (
            <li class="flex items-start gap-3"><span class="text-bronze-500">◆</span>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* ============================================================
      5. 信誉背书
      ============================================================ */}
  <section class="bg-ink-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 grid gap-12 lg:grid-cols-2 items-center">
      <div>
        <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Trust</span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3 mb-5">Booked with confidence</h2>
        <p class="text-ink-500 leading-relaxed mb-6">
          Many international travelers worry about payments, apps and language in China. We remove the friction.
          As a Hong Kong registered company, we operate under transparent terms and partner only with licensed mainland travel agencies.
        </p>
        <ul class="space-y-3 text-sm">
          {[
            'Hong Kong registered business entity',
            'Partnered with licensed mainland travel agencies',
            'Transparent pricing — no hidden shopping stops',
            '24/7 English support throughout your trip',
          ].map((item) => (
            <li class="flex items-start gap-3 text-ink-700">
              <span class="text-vermilion-500 font-bold">✓</span>{item}
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-3xl border border-ink-100 bg-gradient-to-br from-white to-ink-50 p-8 sm:p-10">
        <div class="text-4xl mb-4">🛡️</div>
        <h3 class="font-display text-2xl text-ink-900 mb-2">Hong Kong registered</h3>
        <p class="text-sm text-ink-500 mb-6">{SITE.address.line1}, {SITE.address.line2}</p>
        <div class="border-t border-ink-100 pt-6 grid grid-cols-3 gap-4 text-center">
          <div>
            <div class="font-display text-3xl text-vermilion-600">12</div>
            <div class="text-xs text-ink-500 mt-1">Max group</div>
          </div>
          <div>
            <div class="font-display text-3xl text-vermilion-600">11</div>
            <div class="text-xs text-ink-500 mt-1">Itineraries</div>
          </div>
          <div>
            <div class="font-display text-3xl text-vermilion-600">24/7</div>
            <div class="text-xs text-ink-500 mt-1">English support</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================
      6. 最终 CTA
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="relative rounded-3xl overflow-hidden bg-vermilion-500 text-white p-10 sm:p-16 md:p-20 text-center">
      {/* 装饰光晕 */}
      <div class="absolute -top-20 -right-20 h-64 w-64 rounded-full bg-white/10 blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 h-64 w-64 rounded-full bg-ink-900/20 blur-3xl"></div>

      <div class="relative">
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl mb-4">Ready to discover the real China?</h2>
        <p class="text-white/90 max-w-xl mx-auto mb-8">
          Tell us your dates and interests. We'll design a study tour that fits your group.
        </p>
        <Button href="/contact" variant="onDark" size="lg">Plan My Trip →</Button>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  // ============================================================
  // Hero 背景图轮播逻辑
  // - 每 5 秒自动切换到下一张
  // - 点击底部标签手动切换
  // - 切换时 1500ms 交叉淡入淡出
  // ============================================================
  const slides = document.querySelectorAll('.hero-slide');
  const tabs = document.querySelectorAll('.hero-tab');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function show(index: number) {
    if (index === current) return;
    slides[current]?.classList.replace('opacity-100', 'opacity-0');
    slides[index]?.classList.replace('opacity-0', 'opacity-100');
    tabs[current]?.classList.remove('bg-white', 'text-ink-900');
    tabs[current]?.classList.add('text-white/60');
    tabs[index]?.classList.add('bg-white', 'text-ink-900');
    tabs[index]?.classList.remove('text-white/60');
    current = index;
  }

  function next() {
    show((current + 1) % slides.length);
  }

  function startAuto() {
    clearInterval(timer);
    timer = setInterval(next, 5000);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = Number(tab.dataset.target);
      show(target);
      startAuto(); // 手动切换后重置计时器
    });
  });

  startAuto();
</script>

  startAuto();
</script>
