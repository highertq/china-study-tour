---
// =============================================================================
// 首页 index.astro —— 全站最重要的 SEO 入口
//
// 设计升级：借鉴电影感 Hero（背景图交叉淡入淡出 + 标签切换）
//   - 背景：4 张中国地标图交叉切换（替代了原提示词里的视频，更轻量对 SEO 更好）
//   - 标题：Instrument Serif 衬线体，编辑感、高级
//   - 元素：液态玻璃徽章、CTA
//   - 下面保留所有 SEO 内容区块
// =============================================================================
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import ContactChannels from '../components/ContactChannels.astro';
import TourImage from '../components/TourImage.astro';
import { SITE } from '../site.config';
import { getCollection } from 'astro:content';
import { getFeaturedTours, getAllCategories } from '../lib/tours';

const featuredTours = await getFeaturedTours(3);
const categories = await getAllCategories();

// Hero 背景图轮播：4 个标志性场景（古文明 × 科技）
const heroSlides = [
  { src: '/images/tours/beijing-ancient-tech.jpg', label: 'The Great Wall', sub: 'Beijing' },
  { src: '/images/tours/xian-ancient-capital.jpg', label: 'Terracotta Army', sub: 'Xi’an' },
  { src: '/images/tours/shanghai-future-past.jpg', label: 'The Bund', sub: 'Shanghai' },
  { src: '/images/tours/chengdu-pandas-sanxingdui.jpg', label: 'Giant Pandas', sub: 'Chengdu' },
];
---

<BaseLayout
  title=""
  description={SITE.description}
  hero={true}
>
  {/* ============================================================
      1. 电影感 Hero —— 背景图交叉淡入淡出 + 衬线体大标题
      ============================================================ */}
  <section class="relative w-full min-h-screen overflow-hidden bg-black">
    {/* 背景图层：4 张图绝对定位，opacity 切换 */}
    <div class="absolute inset-0">
      {heroSlides.map((slide, i) => (
        <div
          class:list={["hero-slide absolute inset-0 transition-opacity duration-[1500ms] ease-in-out", i === 0 ? 'opacity-100' : 'opacity-0']}
          data-index={i}
        >
          <img src={slide.src} alt={slide.label} class="w-full h-full object-cover animate-ken-burns" />
          {/* 暗色渐变遮罩，让前景文字可读 */}
          <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/70"></div>
        </div>
      ))}
    </div>

    {/* 内容层 */}
    <div class="relative z-10 flex flex-col min-h-screen px-4 sm:px-6">
      <Header transparent />

      {/* Hero 主体内容，居中 */}
      <div class="flex-1 flex flex-col items-center justify-center text-center text-white pt-20 pb-12">
        {/* 徽章：液态玻璃 */}
        <div class="liquid-glass rounded-full px-5 py-2 text-xs sm:text-sm text-white/90 mb-8 animate-rise" style="animation-delay: 100ms">
          ✦ Private China journeys · Hong Kong based
        </div>

        {/* H1：Instrument Serif 衬线体大标题（专业权威主张） */}
        <h1 class="font-display text-4xl sm:text-6xl md:text-7xl lg:text-[5.5rem] leading-[1.05] max-w-5xl animate-rise" style="animation-delay: 300ms">
          The professional<br />
          way into <em class="text-vermilion-500 not-italic">China</em>.
        </h1>

        <p class="mt-8 text-base sm:text-lg text-white/75 max-w-xl leading-relaxed animate-rise" style="animation-delay: 500ms">
          {SITE.subtitle}
        </p>

        {/* CTA 按钮 */}
        <div class="mt-10 flex flex-wrap gap-4 justify-center animate-rise" style="animation-delay: 700ms">
          <Button href="/tours" variant="primary" size="lg">Explore Tours →</Button>
          <Button href="/contact" variant="glassOnDark" size="lg">Plan My Trip</Button>
        </div>

        {/* 背景图切换器：4 个标签 */}
        <div class="mt-16 flex flex-wrap gap-1 sm:gap-2 justify-center animate-rise" style="animation-delay: 900ms">
          {heroSlides.map((slide, i) => (
            <button
              class:list={["hero-tab px-4 py-2 text-xs sm:text-sm rounded-full transition-all duration-300", i === 0 ? 'bg-white text-ink-900' : 'text-white/60 hover:text-white']}
              data-target={i}
            >
              {slide.label}
            </button>
          ))}
        </div>
      </div>

      {/* 底部信任元素 */}
      <div class="pb-8 flex flex-wrap gap-x-8 gap-y-3 justify-center text-xs sm:text-sm text-white/60">
        <span>✓ Hong Kong registered</span>
        <span>✓ English-speaking guides</span>
        <span>✓ Max 12 travelers</span>
        <span class="hidden sm:inline">✓ Pre-trip Chinese course</span>
      </div>
    </div>
  </section>

  {/* ============================================================
      2. 产品矩阵 bar —— 4 大分类入口（学竞品 WHAT WE DO 结构）
         老外进来一眼看到"我们有 4 类选择"，决策路径最短
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">What we do</span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">Start with why you're coming to China</h2>
      <p class="mt-4 text-ink-500">Four kinds of trips, one team that knows China inside out. Pick what fits — or tell us your idea and we'll design from scratch.</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {categories.map((cat) => (
        <a href={`/tours/${cat.id}`} class="group rounded-2xl border border-ink-100 bg-white p-6 hover:shadow-xl hover:border-vermilion-500/30 transition-all duration-300 hover:-translate-y-1 flex flex-col">
          <div class="text-3xl mb-3">
            {cat.id === 'journeys' && '🗺️'}
            {cat.id === 'experiences' && '🧭'}
            {cat.id === 'business' && '🤝'}
            {cat.id === 'special' && '🌸'}
          </div>
          <h3 class="font-display text-xl text-ink-900 group-hover:text-vermilion-600 transition-colors">{cat.name}</h3>
          <p class="mt-2 text-sm text-ink-500 leading-relaxed flex-1">{cat.tagline}</p>
          <div class="mt-4 pt-4 border-t border-ink-100 flex items-center justify-between">
            <span class="text-xs text-ink-500">{cat.hasTours ? `${cat.count} sample routes` : 'By request'}</span>
            <span class="text-sm text-vermilion-600 font-medium group-hover:translate-x-1 transition-transform">Explore →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {/* ============================================================
      3. 为什么选我们 —— 4 个差异化卖点
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Why us</span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">Travel China with people who know it</h2>
      <p class="mt-4 text-ink-500">We handle the parts foreigners can't easily do alone — payments, apps, language, access — so you can focus on the country, not the logistics.</p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { icon: '🧭', title: 'Built by locals', desc: 'Designed by people who actually live in China. We know the routes, the seasons, and the places worth your time — and the ones that aren\'t.' },
        { icon: '🔑', title: 'Access you can\'t get alone', desc: 'Factories, hidden neighborhoods, family-run workshops, English-speaking specialists. The China most foreign travelers never reach.' },
        { icon: '💬', title: 'Language & logistics handled', desc: 'Payments, apps, trains, translation — set up before you land, supported 24/7 in English while you\'re here.' },
        { icon: '🛡️', title: 'Trusted Hong Kong base', desc: 'Hong Kong registered company, partnered with licensed mainland travel agencies. Transparent pricing, no hidden stops.' },
      ].map((item) => (
        <div class="group rounded-2xl border border-ink-100 bg-white p-6 hover:shadow-xl hover:border-vermilion-500/30 transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-4 transition-transform group-hover:scale-110">{item.icon}</div>
          <h3 class="font-display text-xl text-ink-900 mb-2">{item.title}</h3>
          <p class="text-sm text-ink-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ============================================================
      3. 热门路线
      ============================================================ */}
  <section class="bg-ink-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="flex items-end justify-between mb-12">
        <div>
          <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Tours</span>
          <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">Featured journeys</h2>
          <p class="mt-3 text-ink-500">Curated itineraries designed around school holiday windows.</p>
        </div>
        <a href="/tours" class="hidden sm:inline-flex items-center gap-1 font-semibold text-vermilion-600 hover:text-vermilion-700">
          View all tours →
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {featuredTours.map((tour) => (
          <a href={`/tours/${tour.slug}`} class="group rounded-2xl bg-white overflow-hidden border border-ink-100 hover:shadow-2xl transition-all duration-500">
            <div class="aspect-[16/10] overflow-hidden">
              <TourImage src={tour.data.cardImage || tour.data.heroImage} alt={tour.data.title} className="group-hover:scale-105 transition-transform duration-700" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-2 text-xs text-ink-500 mb-2">
                <span>{tour.data.duration} days</span>
                <span>·</span>
                <span>{tour.data.cities}</span>
              </div>
              <h3 class="font-display text-xl text-ink-900 group-hover:text-vermilion-600 transition-colors">{tour.data.title}</h3>
              <p class="mt-2 text-sm text-ink-500 line-clamp-2">{tour.data.shortDescription}</p>
              <div class="mt-4 flex items-center justify-between">
                <span class="font-semibold text-vermilion-600">From ${tour.data.priceFrom}</span>
                <span class="text-sm text-ink-500 group-hover:text-vermilion-600 transition-colors">Details →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ============================================================
      4. 中国的多个面 —— 6 个维度，扩大受众（不只古+科）
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Many Chinas</span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">A country bigger than the headlines</h2>
      <p class="mt-4 text-ink-500">Whatever brings you to China, there's a version of it here that will surprise you. We build journeys around what you actually care about — not a fixed package.</p>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {[
        { icon: '🏯', title: 'Ancient wonders', desc: 'Great Wall, Terracotta Army, Forbidden City, 1,000-year-old gardens. The civilization that shaped East Asia.' },
        { icon: '🌆', title: 'Modern megacities', desc: 'Shanghai’s Bund, Shenzhen’s skyline, Beijing’s 798. Cities that grew from nothing in 40 years.' },
        { icon: '🍜', title: 'Food & street life', desc: 'Eight regional cuisines, night markets, wet markets, family kitchens. The real version of what the world calls “Chinese food.”' },
        { icon: '🏔️', title: 'Nature & landscapes', desc: 'Karst mountains of Guilin, Zhangjiajie’s pillars, Hainan’s tropical coast, Guizhou’s green gorges.' },
        { icon: '🎭', title: 'Ethnic cultures', desc: '56 ethnic groups. Miao villages, Hakka roundhouses, Tibetan monasteries, Uyghur bazaars — most visitors never reach them.' },
        { icon: '🚀', title: 'Tech & innovation', desc: 'Driverless taxis, the world’s largest port, drone capitals, rocket launches. See the future being built, today.' },
      ].map((item) => (
        <div class="group rounded-2xl border border-ink-100 bg-white p-6 hover:shadow-xl hover:border-vermilion-500/30 transition-all duration-300 hover:-translate-y-1">
          <div class="text-3xl mb-3 transition-transform group-hover:scale-110">{item.icon}</div>
          <h3 class="font-display text-xl text-ink-900 mb-2">{item.title}</h3>
          <p class="text-sm text-ink-500 leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </section>

  {/* ============================================================
      5. 科技冲击专区 —— 具体的、有名的、可查证的中国科技项目
         这是项目的灵魂：用真实项目让老外"哇"，而不是空话
      ============================================================ */}
  <section class="bg-ink-900 text-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-bronze-500 font-medium text-sm uppercase tracking-wider">Access most travelers never get</span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl mt-3">What you can reach through us</h2>
        <p class="mt-4 text-white/60">
          These aren't tourist shows — they're real factories, real labs, real operations. The kind of access ordinary tour companies simply cannot arrange.
        </p>
      </div>

      {/* 科技项目卡片网格：每个都是真实存在、有名字、可查证的项目 */}
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {[
          {
            img: '/images/tours/tech-robotaxi.jpg',
            tag: 'Autonomous',
            title: 'Ride a driverless taxi',
            desc: 'Hail a Robotaxi with no safety driver on public streets. Companies like Pony.ai and WeRide operate paid rides in Beijing, Guangzhou and Shenzhen — something still illegal in most of the West.',
            stat: 'L4 autonomy',
          },
          {
            img: '/images/tours/tech-drone.jpg',
            tag: 'Drones',
            title: 'Inside DJI’s Sky City',
            desc: '70% of the world’s drones come from one company. Visit DJI’s floating-glass headquarters in Shenzhen, test-fly the latest models, and see where the global drone industry was built.',
            stat: '70% global share',
          },
          {
            img: '/images/tours/tech-smart-port.jpg',
            tag: 'Mega-infrastructure',
            title: 'The largest automated port',
            desc: 'Yangshan Port moves 40 million containers a year with almost no humans. Watch AI-controlled bridge cranes and driverless trucks orchestrate cargo at a scale nowhere else matches.',
            stat: '40M containers/yr',
          },
          {
            img: '/images/tours/tech-fast-telescope.jpg',
            tag: 'Big Science',
            title: 'FAST — the world’s largest eye',
            desc: 'A 500-meter radio telescope built into a Guizhou mountain. Bigger than 30 football fields. It listens for pulsars and alien signals at a sensitivity no other instrument can match.',
            stat: '500m diameter',
          },
          {
            img: '/images/tours/tech-rocket.jpg',
            tag: 'Space',
            title: 'Watch a rocket launch',
            desc: 'Witness a Long March rocket lift off from Wenchang — China’s Cape Canaveral. With timing, you can feel the rumble from the public viewing area as satellites head to orbit.',
            stat: '50+ launches/yr',
          },
          {
            img: '/images/tours/shenzhen-china-speed.jpg',
            tag: 'Smart manufacturing',
            title: 'A car every 76 seconds',
            desc: 'Step inside Xiaomi’s megafactory, where robotic arms assemble the SU7 electric sedan in a fully automated line. A phone company now builds cars faster than legacy automakers.',
            stat: '76-sec cycle',
          },
        ].map((item) => (
          <div class="group rounded-2xl overflow-hidden bg-white/5 ring-1 ring-white/10 hover:ring-bronze-500/50 transition-all duration-500 hover:-translate-y-1">
            <div class="aspect-[16/10] overflow-hidden relative">
              <img src={item.img} alt={item.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
              <div class="absolute inset-0 bg-gradient-to-t from-ink-900/80 to-transparent"></div>
              <span class="absolute top-3 left-3 liquid-glass rounded-full px-3 py-1 text-xs font-medium text-white">{item.tag}</span>
            </div>
            <div class="p-6">
              <h3 class="font-display text-xl mb-2">{item.title}</h3>
              <p class="text-sm text-white/60 leading-relaxed">{item.desc}</p>
              <div class="mt-4 pt-4 border-t border-white/10 flex items-center justify-between">
                <span class="font-display text-lg text-bronze-500">{item.stat}</span>
                <span class="text-xs text-white/40">Real, visitable</span>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 text-center">
        <p class="text-sm text-white/50 mb-5">These are integrated into specific itineraries — see which tour includes what.</p>
        <Button href="/tours" variant="glassOnDark">See the tours →</Button>
      </div>
    </div>
  </section>

  {/* ============================================================
      6. 信誉背书
      ============================================================ */}
  <section class="bg-ink-50 py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 grid gap-12 lg:grid-cols-2 items-center">
      <div>
        <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Trust</span>
        <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3 mb-5">Booked with confidence</h2>
        <p class="text-ink-500 leading-relaxed mb-6">
          Many international travelers worry about payments, apps and language in China. We remove the friction — with total transparency about what you're paying for.
        </p>
        <ul class="space-y-3 text-sm">
          {[
            'Hong Kong registered business entity',
            'Transparent 4-step process — see exactly what happens, what it costs',
            'US$150 design fee fully credited to your trip',
            'No hidden shopping stops or commission traps',
            '24/7 English support throughout your trip',
          ].map((item) => (
            <li class="flex items-start gap-3 text-ink-700">
              <span class="text-vermilion-500 font-bold">✓</span>{item}
            </li>
          ))}
        </ul>
        <div class="mt-6">
          <Button href="/how-it-works" variant="ghost">See how it works →</Button>
        </div>
      </div>

      <div class="rounded-3xl border border-ink-100 bg-gradient-to-br from-white to-ink-50 p-8 sm:p-10">
        <div class="text-4xl mb-4">🛡️</div>
        <h3 class="font-display text-2xl text-ink-900 mb-2">Hong Kong registered</h3>
        <p class="text-sm text-ink-500 mb-6">{SITE.address.line1}, {SITE.address.line2}</p>
        <div class="border-t border-ink-100 pt-6 grid grid-cols-3 gap-4 text-center">
          <div>
            <div class="font-display text-3xl text-vermilion-600">13</div>
            <div class="text-xs text-ink-500 mt-1">Itineraries</div>
          </div>
          <div>
            <div class="font-display text-3xl text-vermilion-600">12</div>
            <div class="text-xs text-ink-500 mt-1">Max group</div>
          </div>
          <div>
            <div class="font-display text-3xl text-vermilion-600">24/7</div>
            <div class="text-xs text-ink-500 mt-1">English support</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============================================================
      6.5 FAQ —— 询盘转化临门一脚，解决高频犹豫
      ============================================================ */}
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center mb-12">
      <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">FAQ</span>
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl text-ink-900 mt-3">Questions, answered</h2>
    </div>

    <div class="space-y-3">
      {[
        {
          q: 'Do I need a visa for China?',
          a: 'Maybe not. China now offers visa-free entry (15-30 days) to 50+ countries including most of the EU, Malaysia, Australia, and New Zealand. The 144-hour transit visa is another option if you have an onward ticket. For longer stays, we provide invitation letters for L visa applications. Check your nationality\'s current policy — we\'ll help you figure out the right path.',
        },
        {
          q: 'Is it safe? Will the internet/apps work?',
          a: 'China is one of the safest countries on earth for travelers — violent crime against foreigners is extremely rare. Google, WhatsApp, and Instagram are blocked, but we help you install a VPN before landing and set up WeChat Pay / Alipay / Didi so you\'re fully functional from day one. See our Travel Help guide for details.',
        },
        {
          q: 'I don\'t speak any Chinese. Is that a problem?',
          a: 'No. All our journeys include English-speaking guides and 24/7 English support. We also provide a free pre-trip Chinese starter course and set up translation apps on your phone. Most travelers find they get by easily with our support.',
        },
        {
          q: 'Can I really visit factories and ride driverless taxis?',
          a: 'Yes — these are real places, not stage sets. Some visits (DJI showroom, Huawei campus, public Robotaxi rides) are open to anyone. Others (Xiaomi factory, Baidu Apollo, Yangshan Port) require advance arrangement, which we handle. We tell you honestly what\'s bookable for your dates.',
        },
        {
          q: 'What\'s the group size? Can I do a private trip?',
          a: 'All our journeys are private — just you and your group. No mixed groups with strangers. There\'s no minimum; we\'ve planned trips for solo travelers, couples, and families of ten. Price per person drops as group size grows.',
        },
        {
          q: 'How much does a trip cost?',
          a: 'Sample itineraries start from $1,680 per person (4-day Shenzhen) up to $4,880 (12-day Grand Tour). Final pricing depends on group size, hotel level, and season. There\'s a US$150 design fee to produce a detailed day-by-day quote, fully credited toward your trip if you book.',
        },
        {
          q: 'When should I book?',
          a: 'For peak seasons (March, June-August, December holidays) book 3-4 months ahead — hotels and factory visits fill up. For shoulder seasons, 6-8 weeks is usually fine. We reply to inquiries within 24 hours regardless.',
        },
      ].map((item) => (
        <details class="group rounded-xl border border-ink-100 bg-white p-5 hover:border-vermilion-500/30 transition-colors">
          <summary class="cursor-pointer font-medium text-ink-900 flex items-center justify-between list-none gap-4">
            <span>{item.q}</span>
            <span class="text-vermilion-500 transition-transform group-open:rotate-45 shrink-0">+</span>
          </summary>
          <p class="mt-3 text-sm text-ink-500 leading-relaxed">{item.a}</p>
        </details>
      ))}
    </div>

    <div class="mt-8 text-center">
      <a href="/travel-help" class="text-sm text-vermilion-600 hover:underline">More practical questions? See our full Travel Help guide →</a>
    </div>
  </section>

  {/* ============================================================
      7. 客户评价占位区（信任建设的核心：老外看评价做决策）
         ⚠️ 现在是占位文案，等你有了真实客户后，把这些换成真实故事 + 真名 + 国籍
      ============================================================ */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-20 sm:py-28">
    <div class="text-center max-w-2xl mx-auto mb-16">
