---
// =============================================================================
// 目的地详情页 /destinations/[id]
// 学竞品 goinsidechina.com/destination-xxx 结构：
//   定位 → 亮点 → 实用信息 → 相关路线 → 周边城市
// SEO 长尾流量入口（"beijing travel""shenzhen tech tour"）
// =============================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import TourImage from '../../components/TourImage.astro';
import TourCard from '../../components/TourCard.astro';
import Button from '../../components/Button.astro';
import { DESTINATIONS } from '../../data/destinations.js';
import { getCollection } from 'astro:content';

// 1. 生成静态路径
export async function getStaticPaths() {
  return DESTINATIONS.map((dest) => ({
    params: { id: dest.id },
    props: { destination: dest },
  }));
}

const { destination } = Astro.props;

// 2. 找出该城市相关的路线（用 cities 字段包含城市名判断）
const allTours = await getCollection('tours');
const cityName = destination.name.toLowerCase();
const relatedTours = allTours
  .filter((t) => t.data.cities.toLowerCase().includes(cityName))
  .sort((a, b) => a.data.priceFrom - b.data.priceFrom);

// 3. 周边城市（转成完整对象）
const nearby = destination.nearby
  .map((id) => DESTINATIONS.find((d) => d.id === id))
  .filter(Boolean);

const seoTitle = `${destination.name} Travel Guide — What to See & Do`;
const seoDescription = `${destination.tagline}. ${destination.intro.slice(0, 140)} Plan your ${destination.name} trip with China Crossroads.`;
---

<BaseLayout title={seoTitle} description={seoDescription}>
  {/* Hero 大图 + 定位 */}
  <section class="relative h-[60vh] min-h-[420px] overflow-hidden">
    <div class="absolute inset-0">
      <img src={destination.heroImage} alt={destination.name} class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/40 to-ink-900/90"></div>
    </div>
    <div class="relative h-full mx-auto max-w-5xl px-4 sm:px-6 flex flex-col justify-end pb-12 text-white">
      <a href="/destinations" class="text-sm text-white/60 hover:text-white mb-4 inline-block">← All destinations</a>
      <h1 class="font-display text-5xl sm:text-6xl md:text-7xl">{destination.name}</h1>
      <p class="mt-3 text-lg sm:text-xl text-white/80 max-w-2xl font-display italic">{destination.tagline}</p>
    </div>
  </section>

  {/* 城市介绍 */}
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-16 sm:py-20">
    <p class="text-lg text-ink-700 leading-relaxed">{destination.intro}</p>
  </section>

  {/* 亮点（What you'll see） */}
  <section class="bg-ink-50 py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <h2 class="font-display text-3xl sm:text-4xl text-ink-900 mb-10">What you\'ll see in {destination.name}</h2>
      <div class="grid gap-6 sm:grid-cols-2">
        {destination.highlights.map((h) => (
          <div class="rounded-2xl bg-white p-6 border border-ink-100 hover:border-vermilion-500/30 transition-colors">
            <h3 class="font-display text-xl text-ink-900 mb-2">{h.title}</h3>
            <p class="text-sm text-ink-500 leading-relaxed">{h.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* 实用信息 */}
  <section class="mx-auto max-w-3xl px-4 sm:px-6 py-16 sm:py-24">
    <h2 class="font-display text-3xl text-ink-900 mb-8">Practical info</h2>
    <div class="grid sm:grid-cols-2 gap-6">
      <div class="rounded-xl border border-ink-100 p-5">
        <div class="text-xs text-vermilion-600 uppercase tracking-wider font-medium mb-1">Best time</div>
        <div class="text-ink-700">{destination.practical.bestTime}</div>
      </div>
      <div class="rounded-xl border border-ink-100 p-5">
        <div class="text-xs text-vermilion-600 uppercase tracking-wider font-medium mb-1">Recommended stay</div>
        <div class="text-ink-700">{destination.practical.stayDays}</div>
      </div>
      <div class="rounded-xl border border-ink-100 p-5">
        <div class="text-xs text-vermilion-600 uppercase tracking-wider font-medium mb-1">Getting there</div>
        <div class="text-ink-700">{destination.practical.getThere}</div>
      </div>
      <div class="rounded-xl border border-ink-100 p-5">
        <div class="text-xs text-vermilion-600 uppercase tracking-wider font-medium mb-1">Getting around</div>
        <div class="text-ink-700">{destination.practical.getAround}</div>
      </div>
    </div>
  </section>

  {/* 相关路线 */}
  {relatedTours.length > 0 && (
    <section class="bg-ink-50 py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <h2 class="font-display text-3xl sm:text-4xl text-ink-900 mb-3">Tours through {destination.name}</h2>
        <p class="text-ink-500 mb-10">Ready-made itineraries that include this city.</p>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {relatedTours.slice(0, 3).map((tour) => (
            <TourCard tour={tour} />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* 周边城市 */}
  {nearby.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-24">
      <h2 class="font-display text-3xl text-ink-900 mb-8">Nearby destinations</h2>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {nearby.map((dest) => (
          <a href={`/destinations/${dest.id}`} class="group rounded-2xl overflow-hidden bg-white border border-ink-100 hover:shadow-xl hover:border-vermilion-500/30 transition-all flex">
            <div class="w-32 shrink-0 overflow-hidden">
              <TourImage src={dest.heroImage} alt={dest.name} />
            </div>
            <div class="p-5 flex flex-col justify-center">
              <h3 class="font-display text-lg text-ink-900 group-hover:text-vermilion-600 transition-colors">{dest.name}</h3>
              <p class="text-xs text-ink-500 mt-1 line-clamp-2">{dest.tagline}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* CTA */}
  <section class="bg-ink-900 text-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 text-center">
      <h2 class="font-display text-3xl sm:text-4xl mb-4">Want {destination.name} in your trip?</h2>
      <p class="text-white/70 mb-8 max-w-xl mx-auto">
        We build private journeys that include {destination.name} and beyond. Tell us your dates and we'll handle the rest.
      </p>
      <Button href="/contact" variant="onDark" size="lg">Plan my trip →</Button>
    </div>
  </section>
</BaseLayout>
