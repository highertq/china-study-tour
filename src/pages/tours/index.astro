---
// =============================================================================
// 路线总览页 /tours —— 产品矩阵首页
//
// 4 大服务形态分类：
//   - Private Journeys（有 13 条路线）：分组展示内部主题
//   - Local Experiences / Business / Special-Purpose：卡片引导到询盘落地页
// =============================================================================
import BaseLayout from '../../layouts/BaseLayout.astro';
import TourCard from '../../components/TourCard.astro';
import { CATEGORIES } from '../../content.config.js';
import { getAllCategories, getCategoryWithTours } from '../../lib/tours';

const categories = await getAllCategories();
const journeys = await getCategoryWithTours('journeys');
const journeysTours = journeys?.tours || [];

const description =
  'Private China journeys, local experiences, business visits, and special-purpose trips — designed by a team that knows China inside out. Start with what brings you here.';
---

<BaseLayout title="Private China Journeys" description={description}>
  {/* 页头 */}
  <section class="bg-ink-900 text-white pt-36 pb-16 sm:pt-44 sm:pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <span class="text-vermilion-500 font-medium text-sm uppercase tracking-wider mb-3 block">What we do</span>
      <h1 class="font-display text-4xl sm:text-5xl md:text-6xl">Start with why you're coming to China</h1>
      <p class="mt-5 text-lg text-ink-100/70 max-w-2xl">{description}</p>
    </div>
  </section>

  {/* 4 大分类入口卡（一眼看清产品形态） */}
  <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-20">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {categories.map((cat) => (
        <a href={`/tours/${cat.id}`} class="group rounded-2xl border border-ink-100 bg-white p-6 hover:shadow-xl hover:border-vermilion-500/30 transition-all duration-300 hover:-translate-y-1 flex flex-col">
          <div class="text-3xl mb-3">
            {cat.id === 'journeys' && '🗺️'}
            {cat.id === 'experiences' && '🧭'}
            {cat.id === 'business' && '🤝'}
            {cat.id === 'special' && '🌸'}
          </div>
          <h2 class="font-display text-xl text-ink-900 group-hover:text-vermilion-600 transition-colors">{cat.name}</h2>
          <p class="mt-2 text-sm text-ink-500 leading-relaxed flex-1">{cat.tagline}</p>
          <div class="mt-4 pt-4 border-t border-ink-100 flex items-center justify-between">
            <span class="text-xs text-ink-500">{cat.hasTours ? `${cat.count} sample routes` : 'By request'}</span>
            <span class="text-sm text-vermilion-600 font-medium">Explore →</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  {/* Private Journeys 样本路线（主推，13 条全展示） */}
  {journeysTours.length > 0 && (
    <section class="mx-auto max-w-7xl px-4 sm:px-6 py-16 sm:py-24">
      <div class="flex items-end justify-between mb-8 gap-4">
        <div>
          <span class="text-vermilion-600 font-medium text-sm uppercase tracking-wider">Sample itineraries</span>
          <h2 class="font-display text-3xl sm:text-4xl text-ink-900 mt-2">Private Journeys to start from</h2>
          <p class="mt-2 text-ink-500 max-w-2xl">Every route below can be customized to your dates, group size, and interests — or use them as inspiration for a fully bespoke itinerary.</p>
        </div>
        <a href="/tours/journeys" class="hidden sm:inline-flex shrink-0 items-center gap-1 font-semibold text-vermilion-600 hover:text-vermilion-700 whitespace-nowrap">
          View all ({journeysTours.length}) →
        </a>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {journeysTours.map((tour) => (
          <TourCard tour={tour} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
