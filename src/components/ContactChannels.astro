---
// =============================================================================
// ContactChannels —— 多联系渠道卡片组
// 在首页信任区、contact 页、路线详情页询盘卡都能复用
// 解决竞品那种"4 条渠道覆盖老外所有习惯"的信任建设
// =============================================================================
import { SITE } from '../site.config';

interface Props {
  compact?: boolean; // 紧凑模式（详情页侧边栏用）
}
const { compact = false } = Astro.props;

const iconMap: Record<string, string> = {
  whatsapp: '💬',
  email: '✉️',
  wechat: '🟢',
};
---

<div class:list={["grid gap-3", compact ? '' : 'sm:grid-cols-3']}>
  {SITE.contactChannels.map((ch) => (
    <div class="rounded-xl border border-ink-100 bg-white p-4 hover:border-vermilion-500/30 hover:shadow-md transition-all">
      <div class="flex items-start gap-3">
        <span class="text-xl shrink-0">{iconMap[ch.id] || '◉'}</span>
        <div class="min-w-0">
          <div class="font-semibold text-ink-900 text-sm">{ch.label}</div>
          <div class="text-sm text-vermilion-600 break-all mt-0.5">
            {ch.id === 'email' ? <a href={`mailto:${ch.handle}`} class="hover:underline">{ch.handle}</a> : ch.handle}
          </div>
          <div class="text-xs text-ink-500 mt-1">{ch.note}</div>
        </div>
      </div>
    </div>
  ))}
</div>
